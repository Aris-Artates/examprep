# ============================================================
#  .env.example — Copy to .env and fill in ALL values marked
#  with  ← FILL IN  before running docker compose.
#  Never commit .env to git.
# ============================================================

NODE_ENV=development

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co        # ← FILL IN
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here                    # ← FILL IN
SUPABASE_URL=https://your-project-id.supabase.co                    # ← FILL IN (same as above)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here                # ← FILL IN (secret, never expose)

# ── Google OAuth ──────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Then add to Supabase: Authentication → Providers → Google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com   # ← FILL IN
GOOGLE_CLIENT_SECRET=your_google_client_secret                      # ← FILL IN

# ── Anthropic (LLM for result narration) ─────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here                              # ← FILL IN

# ── Internal Service URLs (no changes needed for local dev) ──
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_AI_URL=http://localhost:8001
BACKEND_URL=http://backend:8000
AI_SERVICE_URL=http://ai:8001

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_64char_string_here                     # ← FILL IN

# ── Redis (no change needed for local dev) ────────────────────
REDIS_URL=redis://redis:6379
